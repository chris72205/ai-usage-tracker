{
  "manifest_version": 3,
  "name": "AI Usage Tracker",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-usage-tracker@localhost",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "js": ["intercept.js"],
    "run_at": "document_start",
    "world": "MAIN"
  }]
}
