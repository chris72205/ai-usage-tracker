{
  "manifest_version": 3,
  "name": "AI Usage Tracker",
  "version": "1.0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-usage-tracker@localhost",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}
