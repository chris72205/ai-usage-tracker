PORT=8080

# Identifies the source platform in routing keys: usage.<PLATFORM>.<window>
# e.g. "claude", "codex", "copilot"
PLATFORM=claude

# Shared Redis instance required for cross-pod deduplication
REDIS_URL=redis://redis:6379/0
# Prefix for all Redis keys — avoids collisions when sharing a Redis instance across services
SERVICE_NAME=ai-usage-svc
# Captures arriving within this window after the first are discarded (default: 30)
DEDUP_WINDOW_SECONDS=30

RABBITMQ_URL=amqp://user:password@rabbitmq:5672/
# Topic exchange — consumers bind with patterns like usage.claude.# or usage.*.five_hour
RABBITMQ_EXCHANGE=usage

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=your-org
INFLUX_BUCKET=ai-agent-usages
